<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <!--
      Mirrors Maven Central when repo.maven.apache.org times out.
      If you rely on a proxy in %USERPROFILE%\.m2\settings.xml, copy this <mirror>
      into that file instead and remove the "-s" / ".mvn/settings.xml" lines from
      .mvn/maven.config (keep "-U" there only if you want forced metadata refresh).
    -->
    <mirrors>
        <mirror>
            <id>aliyun-central</id>
            <mirrorOf>central</mirrorOf>
            <name>Aliyun mirror of Maven Central</name>
            <url>https://maven.aliyun.com/repository/central</url>
        </mirror>
    </mirrors>
</settings>
